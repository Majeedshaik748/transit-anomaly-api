# Copy to .env and adjust. Not loaded automatically unless you add
# python-dotenv loading to api/main.py — kept simple here since most
# deploy targets (Render, etc.) inject env vars natively rather than
# reading a .env file.

# Defaults to a local SQLite file if unset. Set to a Postgres URL
# (e.g. from Render's free Postgres instance) for any deployment with
# an ephemeral or otherwise non-persistent filesystem.
DATABASE_URL=sqlite:///./transit_anomalies.db

# How often the ingest job polls the MTA feed, in seconds. MTA refreshes
# its own feed roughly every 30s, so polling much faster than that
# doesn't get you fresher data — it just adds load for no signal.
POLL_INTERVAL_SECONDS=30
